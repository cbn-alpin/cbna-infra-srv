# /etc/cron.d/backups: execute all backups tasks
# Copy this file into /etc/cron.d/ without .cron extension : cp backups.cron /etc/cron.d/backups
# WARNING: not use "." or "-" in script filename. With this characters, the script will not be
# executed by Cron !?

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
# MAILFROM doesn't work now, use alternative below
MAILTO=adminsys@cbn-alpin.fr
#MAILFROM=mailer@cbn-alpin.fr

# ==================== TÂCHES PLANIFIÉES DE SAUVEGARDE DES CONTAINERS DOCKER ====================
# Sauvegardes quotidiennes planifiées à partir de 1h00, avec rotation automatique des anciennes données.
# Les sauvegardes des wikis sont particulièrement longues.
# Un espacement de 15 minutes est laissé entre chaque tâche pour éviter les chevauchements.

# m h dom mon dow user  command
# Sauvegarde de l’instance WordPress de test (cms-cbna-wordpress-test)
0 1 * * * admin /home/admin/docker/cms-cbna-wordpress-test/backup.sh > /dev/null 2>&1

# Sauvegarde de l’instance WordPress de production (cms-cbna-wordpress)
5 1 * * * admin /home/admin/docker/cms-cbna-wordpress/backup.sh > /dev/null 2>&1

# Sauvegarde de l’instance Joomla (cms-cbna-joomla) — script désactivé car le conteneur est arrêté
# 10 1 * * * admin /home/admin/docker/cms-cbna-joomla/backup-cms-cbna-joomla.sh > /dev/null 2>&1

